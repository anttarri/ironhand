{
  "name": "ironhand",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx vercel dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "node --import ./test/register-alias.mjs --test test/*.test.ts",
    "test:ui": "vitest run",
    "test:all": "npm run test && npm run test:ui"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.6.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
